# Kuznitsa / Printer Dashboard — environment variables
#
# Copy this file to `.env` and fill in the values you need, OR export these
# variables in your process manager (e.g. a systemd unit `Environment=` line).
# `.env` itself is gitignored — never commit real secrets.
#
# Everything here is OPTIONAL: the app boots with safe defaults and generates
# what it needs on first run (see notes below).

# --- Auth & security ---------------------------------------------------------

# JWT signing secret. If unset, the app generates a random one on first boot and
# persists it in users.db, so sessions survive restarts. Set this to pin/rotate
# the key explicitly. Changing it invalidates every issued token at once.
#   Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
# FORGE_JWT_SECRET=

# First-run admin account. Username defaults to "admin". If FORGE_ADMIN_PASSWORD
# is unset, a random password is generated and printed ONCE to the log on first
# boot — read it there, log in, and change it. Set both to choose your own.
# FORGE_ADMIN_USERNAME=admin
# FORGE_ADMIN_PASSWORD=

# Cookie Secure flag. Default on (cookies sent only over HTTPS) — correct behind
# a TLS reverse proxy. Set to 0 only if you serve the app over plain HTTP.
# COOKIE_SECURE=1

# --- Web server --------------------------------------------------------------

# Bind address for the built-in server. Default 127.0.0.1 (loopback only) is
# safest behind a reverse proxy / SSH tunnel. Set 0.0.0.0 to expose it directly.
# WEB_HOST=127.0.0.1
# WEB_PORT=8000

# --- Polling -----------------------------------------------------------------

# How often (seconds) to poll each printer, and the max concurrent poll workers.
# POLL_INTERVAL=5
# MAX_WORKERS=10

# -----------------------------------------------------------------------------
# NOT set here — managed in the app's database, edited from the UI:
#   * Printer fleet (hosts, access codes, serials) — Admin → Printers.
#   * Telegram bot token, chat id, notification templates — Settings → Telegram.
#   * Outbound proxy list for the Telegram bot — Settings → Proxy.
# These live in printer_history.db / users.db, not in env or code.
